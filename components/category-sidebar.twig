{# 2-column horizontal category tiles #}
<div class="vv-cat-grid">
    {% for category in categories %}
    <a href="{{ category_url(category) }}" class="vv-cat-tile" style="animation: vv-up .35s ease both {{ loop.index * 0.07 }}s;">
        <div class="vv-cat-tile-bg" {% if category.color %}style="background: {{ category.color }};"{% endif %}></div>
        {% if category.image_path %}
            <img src="{{ storage_url(category.image_path) }}" alt="" class="vv-cat-tile-img">
        {% endif %}
        <div class="vv-cat-tile-body">
            <div class="flex items-center gap-3">
                {% if category.icon_path %}
                <div style="width:36px; height:36px; border-radius:8px; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    {{ editable_icon(category.icon_path, category.id, 'w-5 h-5 text-white', '20') }}
                </div>
                {% endif %}
                <div>
                    <div class="vv-cat-tile-label">{{ editable(category.name,'category',category.id,'name') }}</div>
                    <div class="vv-cat-tile-sub">
                        Browse <span class="vv-cat-arrow">→</span>
                    </div>
                </div>
            </div>
        </div>
    </a>
    {% endfor %}
</div>
