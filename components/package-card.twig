{# Package tile — used inside .vv-pkg-grid #}
<div class="vv-pkg-tile">
    <div class="vv-pkg-tile-img-wrap">
        {% if package.image_path %}
            <img src="{{ storage_url(package.image_path) }}" alt="{{ package.name }}">
        {% else %}
            <div class="vv-pkg-no-img">
                <svg class="w-10 h-10" style="color:var(--vv-surface3);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
        {% endif %}
        {% if package.original_price and package.original_price > package.price %}
            {% set discount = ((1 - package.price / package.original_price) * 100)|round %}
            <div class="vv-pkg-tile-badge">-{{ discount }}%</div>
        {% endif %}
        {% if is_preorder_pending(package) %}
            <div class="vv-pkg-tile-badge" style="background:#d97706;">⏰ Pre-order</div>
        {% endif %}
    </div>
    <div class="vv-pkg-tile-body">
        <a href="{{ package_url(package) }}" class="vv-pkg-tile-name" style="text-decoration:none;">{{ editable(package.name,'package',package.id,'name') }}</a>
        <div class="vv-pkg-tile-footer">
            <div class="flex items-center gap-1">
                <svg class="w-3 h-3 flex-shrink-0" style="color:var(--vv-green);" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/></svg>
                <span class="vv-pkg-tile-price">{{ price(package.price) }}</span>
                {% if package.original_price and package.original_price > package.price %}
                    <span style="font-size:10px; color:var(--vv-dim); text-decoration:line-through; margin-left:2px;">{{ price(package.original_price) }}</span>
                {% endif %}
            </div>
            <button class="vv-pkg-tile-btn flex items-center gap-1"
                    @click.prevent="addItem({{ package|json_encode }})"
                    :disabled="hasItem({{ package.id }}) || loading === {{ package.id }}">
                <span x-show="!hasItem({{ package.id }}) && loading !== {{ package.id }}" class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                    {{ is_preorder_pending(package) ? 'Pre-order' : 'Buy' }}
                </span>
                <span x-show="hasItem({{ package.id }})" x-cloak class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    Added
                </span>
                <span x-show="loading === {{ package.id }}" x-cloak><span class="vv-spinner"></span></span>
            </button>
        </div>
    </div>
</div>
