<footer class="mt-16" style="background:var(--vv-surface); border-top:1px solid var(--vv-border); position:relative; z-index:10;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <div class="flex flex-col sm:flex-row gap-8 justify-between">
            <div class="max-w-[220px]">
                {% if store.logo %}<img src="{{ storage_url(store.logo) }}" alt="{{ store.name|striptags }}" class="h-9 mb-3 object-contain">{% else %}
                <p style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:900; color:var(--vv-text); text-transform:uppercase; margin-bottom:8px;">{{ editable(store.name,'store',store.id,'store_name') }}</p>{% endif %}
                {% if store.description %}<p style="font-size:12px; color:var(--vv-dim); line-height:1.6;">{{ editable(store.description,'store',store.id,'store_description') }}</p>{% endif %}
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
                <div>
                    <p style="font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-dim); margin-bottom:10px;">Store</p>
                    <div class="space-y-2">
                        <a href="/" style="display:block; font-size:13px; font-weight:600; color:var(--vv-muted); text-decoration:none;" onmouseover="this.style.color='var(--vv-text)'" onmouseout="this.style.color='var(--vv-muted)'">Home</a>
                        {% for category in categories|default([])|slice(0,5) %}
                        <a href="{{ category_url(category) }}" style="display:block; font-size:13px; font-weight:600; color:var(--vv-muted); text-decoration:none;" onmouseover="this.style.color='var(--vv-text)'" onmouseout="this.style.color='var(--vv-muted)'">{{ editable(category.name,'category',category.id,'name') }}</a>
                        {% endfor %}
                    </div>
                </div>
                {% if footer_pages|default([])|length > 0 %}
                <div>
                    <p style="font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-dim); margin-bottom:10px;">Info</p>
                    <div class="space-y-2">
                        {% for page in footer_pages %}<a href="/p/{{ page.slug }}" style="display:block; font-size:13px; font-weight:600; color:var(--vv-muted); text-decoration:none;" onmouseover="this.style.color='var(--vv-text)'" onmouseout="this.style.color='var(--vv-muted)'">{{ page.title }}</a>{% endfor %}
                    </div>
                </div>
                {% endif %}
                <div>
                    <p style="font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-dim); margin-bottom:10px;">Connect</p>
                    <div class="flex gap-2 flex-wrap">
                        {% if store.discord_url %}<a href="{{ store.discord_url }}" target="_blank" rel="noopener" class="w-8 h-8 rounded-lg flex items-center justify-center transition-all" style="background:var(--vv-surface2); border:1px solid var(--vv-border); color:var(--vv-muted);" onmouseover="this.style.background='#5865F2'; this.style.color='#fff'; this.style.borderColor='#5865F2'" onmouseout="this.style.background='var(--vv-surface2)'; this.style.color='var(--vv-muted)'; this.style.borderColor='var(--vv-border)'"><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg></a>{% endif %}
                        {% if store.twitter_url %}<a href="{{ store.twitter_url }}" target="_blank" rel="noopener" class="w-8 h-8 rounded-lg flex items-center justify-center transition-all" style="background:var(--vv-surface2); border:1px solid var(--vv-border); color:var(--vv-muted);" onmouseover="this.style.background='#1DA1F2'; this.style.color='#fff'; this.style.borderColor='#1DA1F2'" onmouseout="this.style.background='var(--vv-surface2)'; this.style.color='var(--vv-muted)'; this.style.borderColor='var(--vv-border)'"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>{% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2 mt-8 pt-6" style="border-top:1px solid var(--vv-border);">
            <p style="font-size:11px; color:var(--vv-dim);">&copy; {{ "now"|date("Y") }} {{ editable(store.name,'store',store.id,'store_name') }} — Not affiliated with Mojang.</p>
            {% if not store.hide_branding %}<p style="font-size:11px; color:var(--vv-dim);">Powered by <a href="https://mcsets.com" target="_blank" rel="noopener" class="accent-text" style="text-decoration:none;">MCsets</a></p>{% endif %}
        </div>
    </div>
</footer>
