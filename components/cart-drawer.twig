<div x-show="open" x-cloak @click="open = false" class="fixed inset-0 vv-drawer-back z-50" x-transition.opacity></div>

<div x-show="open" x-cloak
     x-transition:enter="transform transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transform transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     class="fixed right-0 top-0 h-full w-full max-w-[380px] z-50 flex flex-col vv-drawer">

    {# Header #}
    <div class="flex items-center justify-between px-5 py-4 flex-shrink-0" style="border-bottom:1px solid var(--vv-border);">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center accent-bg">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div>
                <p style="font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; color:var(--vv-text); text-transform:uppercase; line-height:1;">Your Cart</p>
                <p style="font-size:11px; color:var(--vv-dim);" x-text="count + ' item' + (count !== 1 ? 's' : '')"></p>
            </div>
        </div>
        <button @click="open = false" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:var(--vv-surface2); border:1px solid var(--vv-border);">
            <svg class="w-3.5 h-3.5" style="color:var(--vv-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>

    {# Player #}
    <div class="px-5 py-3 flex-shrink-0" style="border-bottom:1px solid var(--vv-border);"
         x-data="{ player: JSON.parse(localStorage.getItem('mcsets_player') || 'null') }"
         x-init="window.addEventListener('storage', () => player = JSON.parse(localStorage.getItem('mcsets_player') || 'null'))">
        <template x-if="player">
            <div class="flex items-center gap-3 px-3 py-2.5 rounded-xl" style="background:var(--vv-accent-ghost); border:1px solid color-mix(in srgb, var(--vv-accent), transparent 70%);">
                <div class="relative">
                    <img :src="player.avatar_url" alt="" class="w-9 h-9 rounded-lg object-cover">
                    <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-green-400" style="border:2px solid var(--vv-surface);"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <p style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--vv-dim);">Buying as</p>
                    <p style="font-size:13px; font-weight:800; color:var(--vv-text);" x-text="player.username" class="truncate"></p>
                </div>
                <button @click="localStorage.removeItem('mcsets_player'); localStorage.removeItem('mcsets_player_token'); player = null; window.dispatchEvent(new Event('storage'))"
                        style="font-size:10px; font-weight:700; color:var(--vv-dim); background:rgba(255,255,255,.06); padding:3px 8px; border-radius:6px;">
                    Switch
                </button>
            </div>
        </template>
        <template x-if="!player">
            <button @click="$dispatch('open-login')" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all" style="background:var(--vv-surface2); border:1px solid var(--vv-border); color:var(--vv-muted);" onmouseover="this.style.borderColor='var(--vv-border-hover)'" onmouseout="this.style.borderColor='var(--vv-border)'">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                <span style="font-size:13px; font-weight:700;">Login to continue</span>
                <svg class="w-3.5 h-3.5 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
        </template>
    </div>

    {# Items #}
    <div class="flex-1 overflow-y-auto px-5 py-4 space-y-2">
        <template x-if="items.length === 0">
            <div class="flex flex-col items-center justify-center h-full text-center py-12">
                <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4" style="background:var(--vv-surface2); border:1px solid var(--vv-border);">
                    <svg class="w-6 h-6" style="color:var(--vv-dim);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
                <p style="font-size:14px; font-weight:700; color:var(--vv-muted);">Your cart is empty</p>
                <p style="font-size:12px; color:var(--vv-dim); margin-top:4px;">Browse the store to add items</p>
                <button @click="open = false" class="vv-btn vv-btn-primary mt-4" style="padding:8px 20px; font-size:12px;">Browse Store</button>
            </div>
        </template>

        <template x-for="(item, index) in items" :key="item.gift_card_id || item.id || index">
            <div class="flex gap-3 p-3 rounded-xl transition-all" style="background:var(--vv-surface2); border:1px solid var(--vv-border);">
                <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0" style="background:var(--vv-surface3);">
                    <template x-if="item.image_path"><img :src="item.image_path" alt="" class="w-full h-full object-cover"></template>
                    <template x-if="!item.image_path"><div class="w-full h-full flex items-center justify-center"><svg class="w-5 h-5" style="color:var(--vv-dim);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg></div></template>
                </div>
                <div class="flex-1 min-w-0">
                    <p x-text="item.name" style="font-size:13px; font-weight:700; color:var(--vv-text);" class="truncate"></p>
                    <p style="font-size:11px; color:var(--vv-dim);" x-text="'Qty: ' + (item.quantity || 1)"></p>
                    <template x-if="item.flash_sale_active && item.original_price">
                        <div class="flex items-center gap-1.5 mt-1">
                            <span x-text="formatPrice(item.original_price * (item.quantity || 1))" style="font-size:11px; text-decoration:line-through; color:var(--vv-dim);"></span>
                            <span x-text="formatPrice(item.price * (item.quantity || 1))" class="accent-text" style="font-size:13px; font-weight:800;"></span>
                        </div>
                    </template>
                    <template x-if="!item.flash_sale_active || !item.original_price">
                        <p x-text="formatPrice(item.price * (item.quantity || 1))" class="price-text" style="font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:800; margin-top:2px;"></p>
                    </template>
                </div>
                <button @click="removeItem(item.gift_card_id || item.id)"
                        class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 transition-all self-start mt-0.5"
                        style="color:var(--vv-dim);"
                        onmouseover="this.style.background='rgba(239,68,68,.12)'; this.style.color='#ef4444'"
                        onmouseout="this.style.background='transparent'; this.style.color='var(--vv-dim)'">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
            </div>
        </template>
    </div>

    {# Footer #}
    <div x-show="items.length > 0" class="flex-shrink-0 px-5 pb-5 pt-4 space-y-3" style="border-top:1px solid var(--vv-border);">
        <div class="flex items-center justify-between px-4 py-3 rounded-xl" style="background:var(--vv-surface2);">
            <span style="font-size:13px; font-weight:700; color:var(--vv-muted);">Total</span>
            <span x-text="formatPrice(total)" style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:900; color:var(--vv-green);"></span>
        </div>
        <a href="{{ checkout_url() }}" class="vv-btn vv-btn-primary w-full" style="font-size:14px; padding:12px;">
            Checkout →
        </a>
        <button @click="open = false" class="w-full py-2.5 text-sm font-bold" style="color:var(--vv-dim);">Continue Shopping</button>
    </div>
</div>