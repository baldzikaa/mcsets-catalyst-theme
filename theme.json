{
    "name": "vivid theme",
    "version": "1.0.0",
    "description": "The default SetStore theme with a modern dark design.",
    "author": "Zika",
    "mcsets_version": "1.0",
    "settings": {
        "colors": {
            "type": "group",
            "label": "Colors",
            "settings": {
                "accent_color": {
                    "type": "color",
                    "label": "Accent Color",
                    "default": "#F5A623"
                },
                "card_background": {
                    "type": "color",
                    "label": "Card Background",
                    "default": "rgba(255, 255, 255, 0.03)"
                },
                "background_color": {
                    "type": "color",
                    "label": "Background",
                    "default": "#1a1a17"
                }
            }
        },
        "header": {
            "type": "group",
            "label": "Header",
            "settings": {
                "show_discord": {
                    "type": "checkbox",
                    "label": "Show Discord Link",
                    "default": true
                },
                "show_server_status": {
                    "type": "checkbox",
                    "label": "Show Server Status",
                    "default": true
                }
            }
        },
        "layout": {
            "type": "group",
            "label": "Layout",
            "settings": {
                "show_sidebar": {
                    "type": "checkbox",
                    "label": "Show Category Sidebar",
                    "default": true
                },
                "packages_per_row": {
                    "type": "select",
                    "label": "Packages Per Row",
                    "default": "3",
                    "options": [
                        "2",
                        "3",
                        "4"
                    ]
                }
            }
        }
    },
    "default_settings": {
        "accent_color": "#F5A623",
        "show_discord": true,
        "show_sidebar": true,
        "card_background": "rgba(255, 255, 255, 0.03)",
        "background_color": "#1a1a17",
        "packages_per_row": "3",
        "show_server_status": true
    }
}