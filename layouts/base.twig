<!DOCTYPE html>
<html lang="en" class="overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <title>{% block title %}{{ store.name|striptags }}{% endblock %}</title>
    {% if store.logo %}<link rel="icon" href="{{ storage_url(store.logo) }}">{% endif %}
    <meta name="description" content="{{ store.description|striptags|default('Welcome to ' ~ store.name|striptags) }}">
    {% if store.logo %}<meta property="og:image" content="{{ storage_url(store.logo) }}">{% endif %}
    <meta name="theme-color" content="{{ store.accent_color|default('#4f8ef7') }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    {{ mcsets_head() }}

    <style>
[x-cloak]{display:none!important}
:root {
    --vv-accent:       {{ store.accent_color|default('#4f8ef7') }};
    --vv-accent-dark:  color-mix(in srgb, var(--vv-accent), black 25%);
    --vv-accent-light: color-mix(in srgb, var(--vv-accent), white 20%);
    --vv-accent-ghost: color-mix(in srgb, var(--vv-accent), transparent 85%);
    --vv-bg:           #0c0e14;
    --vv-surface:      #13161f;
    --vv-surface2:     #1a1e2b;
    --vv-surface3:     #1f2535;
    --vv-border:       rgba(255,255,255,0.08);
    --vv-border-hover: rgba(255,255,255,0.15);
    --vv-text:         #eef0f8;
    --vv-muted:        rgba(238,240,248,0.55);
    --vv-dim:          rgba(238,240,248,0.28);
    --vv-green:        #2ecc71;
    --vv-r: 10px; --vv-r-sm: 6px; --vv-r-lg: 14px; --vv-r-xl: 18px;
    --tile-1:#e53e6a; --tile-2:#7c3aed; --tile-3:#d97706;
    --tile-4:#0891b2; --tile-5:#059669; --tile-6:#db2777;
}
*,*::before,*::after{box-sizing:border-box}
body,html{background:var(--vv-bg);color:var(--vv-text);font-family:'Nunito',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--vv-bg)}::-webkit-scrollbar-thumb{background:var(--vv-surface3);border-radius:3px}
.scrollbar-hide{-ms-overflow-style:none;scrollbar-width:none}.scrollbar-hide::-webkit-scrollbar{display:none}
.accent-bg{background-color:var(--vv-accent)!important}.accent-text{color:var(--vv-accent)!important}.price-text{color:var(--vv-green)!important}
.vv-cut{clip-path:polygon(10px 0%,100% 0%,100% calc(100% - 10px),calc(100% - 10px) 100%,0% 100%,0% 10px)}
.vv-cut-sm{clip-path:polygon(6px 0%,100% 0%,100% calc(100% - 6px),calc(100% - 6px) 100%,0% 100%,0% 6px)}
.vv-card{background:var(--vv-surface);border:1px solid var(--vv-border);border-radius:var(--vv-r);transition:border-color .2s,transform .2s,box-shadow .2s}
.vv-card:hover{border-color:var(--vv-border-hover)}
.vv-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 20px;border-radius:var(--vv-r);font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;border:none;transition:all .15s ease;font-family:'Nunito',sans-serif;white-space:nowrap}
.vv-btn-primary{background:var(--vv-accent);color:#fff}.vv-btn-primary:hover{background:var(--vv-accent-light);transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.3)}.vv-btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.vv-btn-secondary{background:var(--vv-surface2);color:var(--vv-muted);border:1px solid var(--vv-border)}.vv-btn-secondary:hover{background:var(--vv-surface3);color:var(--vv-text);border-color:var(--vv-border-hover)}
.vv-btn-ghost{background:transparent;color:var(--vv-muted);border:1.5px solid var(--vv-border)}.vv-btn-ghost:hover{color:var(--vv-text);border-color:var(--vv-border-hover);background:var(--vv-surface2)}
.vv-input{width:100%;background:var(--vv-surface2);border:1.5px solid var(--vv-border);border-radius:var(--vv-r);padding:10px 14px;color:var(--vv-text);font-family:'Nunito',sans-serif;font-size:14px;font-weight:500;transition:border-color .15s,box-shadow .15s;outline:none}
.vv-input::placeholder{color:var(--vv-dim)}.vv-input:focus{border-color:var(--vv-accent);box-shadow:0 0 0 3px var(--vv-accent-ghost)}
.vv-modal-back{background:rgba(5,6,10,.8);backdrop-filter:blur(8px)}
.vv-modal{background:var(--vv-surface);border:1px solid var(--vv-border-hover);border-radius:var(--vv-r-xl);box-shadow:0 24px 64px rgba(0,0,0,.6)}
.vv-topbar{position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(12,14,20,.88);border-bottom:1px solid var(--vv-border);backdrop-filter:blur(12px)}
.vv-topbar-inner{display:flex;align-items:center;height:56px;gap:8px;padding:0 16px;max-width:1280px;margin:0 auto}
.vv-cat-pill{flex-shrink:0;padding:5px 14px;border-radius:20px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--vv-muted);background:transparent;border:1.5px solid transparent;cursor:pointer;text-decoration:none;transition:all .15s ease;white-space:nowrap}
.vv-cat-pill:hover{color:var(--vv-text);background:var(--vv-surface2);border-color:var(--vv-border-hover)}.vv-cat-pill.active{color:#fff;background:var(--vv-accent);border-color:var(--vv-accent)}
.vv-cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
@media(max-width:640px){.vv-cat-grid{grid-template-columns:1fr;gap:10px}}
.vv-cat-tile{position:relative;height:120px;border-radius:var(--vv-r-lg);overflow:hidden;cursor:pointer;text-decoration:none;display:flex;align-items:center;transition:transform .2s ease,box-shadow .2s ease}
@media(max-width:640px){.vv-cat-tile{height:90px}}
.vv-cat-tile:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(0,0,0,.4)}
.vv-cat-tile:hover .vv-cat-tile-img{transform:translateY(-50%) scale(1.08) translateX(-4px)}
.vv-cat-tile:hover .vv-cat-arrow{transform:translateX(4px)}
.vv-cat-tile-bg{position:absolute;inset:0}
.vv-cat-tile-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,0,0,.35) 0%,transparent 60%)}
.vv-cat-tile-body{position:relative;z-index:2;flex:1;padding:0 20px}
.vv-cat-tile-label{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;color:#fff;letter-spacing:.02em;text-transform:uppercase;line-height:1;text-shadow:0 2px 8px rgba(0,0,0,.4)}
@media(max-width:640px){.vv-cat-tile-label{font-size:20px}}
.vv-cat-tile-sub{font-size:12px;color:rgba(255,255,255,.7);margin-top:4px;display:flex;align-items:center;gap:4px;font-weight:600}
.vv-cat-arrow{display:inline-block;transition:transform .2s ease}
.vv-cat-tile-img{position:absolute;right:-10px;top:50%;transform:translateY(-50%);height:130%;width:auto;object-fit:contain;opacity:.35;transition:transform .3s ease;pointer-events:none}
@media(max-width:640px){.vv-cat-tile-img{height:110%;right:-5px;opacity:.25}}
.vv-cat-tile:nth-child(6n+1) .vv-cat-tile-bg{background:var(--tile-1)}
.vv-cat-tile:nth-child(6n+2) .vv-cat-tile-bg{background:var(--tile-2)}
.vv-cat-tile:nth-child(6n+3) .vv-cat-tile-bg{background:var(--tile-3)}
.vv-cat-tile:nth-child(6n+4) .vv-cat-tile-bg{background:var(--tile-4)}
.vv-cat-tile:nth-child(6n+5) .vv-cat-tile-bg{background:var(--tile-5)}
.vv-cat-tile:nth-child(6n+0) .vv-cat-tile-bg{background:var(--tile-6)}
.vv-pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
@media(max-width:768px){.vv-pkg-grid{grid-template-columns:repeat(2,1fr);gap:10px}}
.vv-pkg-tile{background:var(--vv-surface);border:1px solid var(--vv-border);border-radius:var(--vv-r);overflow:hidden;display:flex;flex-direction:column;cursor:pointer;transition:border-color .2s,transform .2s,box-shadow .2s;text-decoration:none}
.vv-pkg-tile:hover{border-color:var(--vv-accent);transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.35)}
.vv-pkg-tile-img-wrap{position:relative;aspect-ratio:1;overflow:hidden;background:var(--vv-surface2)}
.vv-pkg-tile-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .35s ease}
.vv-pkg-tile:hover .vv-pkg-tile-img-wrap img{transform:scale(1.12)}
.vv-pkg-tile-body{padding:10px 12px 12px;display:flex;flex-direction:column;gap:6px;flex:1}
.vv-pkg-tile-name{font-size:13px;font-weight:700;color:var(--vv-text);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.vv-pkg-tile-footer{display:flex;align-items:center;justify-content:space-between;gap:6px;margin-top:auto}
.vv-pkg-tile-price{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:800;color:var(--vv-green)}
.vv-pkg-tile-btn{font-size:11px;font-weight:800;color:#fff;background:var(--vv-accent);border:none;border-radius:var(--vv-r-sm);padding:5px 10px;cursor:pointer;transition:background .15s,transform .15s;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap}
.vv-pkg-tile-btn:hover{background:var(--vv-accent-light);transform:scale(1.05)}.vv-pkg-tile-btn:disabled{opacity:.45;cursor:not-allowed;transform:none}
.vv-section-head{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.vv-section-title{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:var(--vv-text);text-transform:uppercase;letter-spacing:.04em}
.vv-section-line{flex:1;height:1px;background:var(--vv-border)}
.vv-side-card{background:var(--vv-surface);border:1px solid var(--vv-border);border-radius:var(--vv-r-lg);overflow:hidden}
.vv-side-card-head{padding:10px 14px;background:var(--vv-surface2);border-bottom:1px solid var(--vv-border);display:flex;align-items:center;gap:8px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--vv-muted)}
.vv-ring-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center}
.vv-ring-wrap svg{transform:rotate(-90deg)}
.vv-ring-track{fill:none;stroke:var(--vv-surface3)}
.vv-ring-fill{fill:none;stroke:var(--vv-accent);stroke-linecap:round;transition:stroke-dasharray 1s ease}
.vv-ring-label{position:absolute;text-align:center}
.vv-ring-pct{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;color:var(--vv-text);line-height:1}
.vv-ring-sub{font-size:10px;font-weight:700;color:var(--vv-muted);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}
.vv-breadcrumb{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--vv-dim);flex-wrap:wrap}
.vv-breadcrumb a{color:var(--vv-muted);text-decoration:none;transition:color .15s}.vv-breadcrumb a:hover{color:var(--vv-text)}
.vv-avatar{width:36px;height:36px;border-radius:8px;object-fit:cover;border:2px solid var(--vv-surface);transition:transform .15s ease;cursor:default}
.vv-avatar:hover{transform:scale(1.2) translateY(-2px);z-index:10;position:relative}
.vv-hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:blur(8px) brightness(.28) saturate(1.3);transform:scale(1.05)}
.vv-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(12,14,20,.1) 0%,rgba(12,14,20,.6) 70%,rgba(12,14,20,1) 100%)}
.vv-mobile-nav{background:var(--vv-surface);border-top:1px solid var(--vv-border);box-shadow:0 -4px 20px rgba(0,0,0,.4)}
.vv-mobile-nav-item{display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 12px;color:var(--vv-dim);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;cursor:pointer;text-decoration:none;transition:color .15s;flex:1}
.vv-mobile-nav-item:hover,.vv-mobile-nav-item.active{color:var(--vv-accent)}
.vv-drawer{background:var(--vv-surface);border-left:1px solid var(--vv-border);box-shadow:-20px 0 60px rgba(0,0,0,.5)}
@keyframes vv-up{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes vv-in{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
@keyframes vv-spin{to{transform:rotate(360deg)}}
.vv-animate-up{animation:vv-up .4s ease both}
.vv-animate-in{animation:vv-in .3s ease both}
.vv-spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.2);border-top-color:currentColor;border-radius:50%;animation:vv-spin .7s linear infinite;display:inline-block}
.vv-prose{color:var(--vv-muted);font-size:14px;line-height:1.7}
.vv-prose h1,.vv-prose h2,.vv-prose h3{color:var(--vv-text);font-family:'Barlow Condensed',sans-serif;font-weight:800}
.vv-prose a{color:var(--vv-accent)}
.safe-bottom{padding-bottom:env(safe-area-inset-bottom)}
.setstore-payment-backdrop{background:rgba(5,6,10,.85)!important;backdrop-filter:blur(8px)}
.setstore-payment-modal-panel{background:var(--vv-surface)!important;border:1px solid var(--vv-border-hover)!important;border-radius:var(--vv-r-xl)!important}
.setstore-hook-player-info input,.setstore-hook-coupon input{background:var(--vv-surface2)!important;border:1.5px solid var(--vv-border)!important;border-radius:var(--vv-r)!important;color:var(--vv-text)!important;font-family:'Nunito',sans-serif!important}
.setstore-hook-player-info input:focus,.setstore-hook-coupon input:focus{border-color:var(--vv-accent)!important;box-shadow:0 0 0 3px var(--vv-accent-ghost)!important}
.setstore-hook-pay-button button{color:#fff!important;font-family:'Nunito',sans-serif!important;font-weight:800!important}
    </style>
    {% block head %}{% endblock %}
</head>
<body class="min-h-screen pb-16 lg:pb-0" x-data="cartStore()" @toggle-cart.window="open = !open">

    {% if store.sandbox_mode %}
    <div class="relative z-50 px-4 py-2 text-center text-xs font-bold text-black" style="background:#f59e0b;">
        Sandbox Mode — Test purchases only
    </div>
    {% endif %}

    {% block content %}{% endblock %}

    {% include 'components/cart-drawer.twig' %}
    {% include 'components/footer.twig' %}

    {# Mobile bottom nav #}
    <div class="lg:hidden fixed bottom-0 left-0 right-0 vv-mobile-nav z-40 safe-bottom">
        <div class="flex h-14 px-2">
            <a href="/" class="vv-mobile-nav-item">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Home
            </a>
            <button @click="$dispatch('toggle-mobile-cats')" class="vv-mobile-nav-item">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                Categories
            </button>
            <button @click="$dispatch('toggle-cart')" class="vv-mobile-nav-item relative">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                Cart
                <span x-show="$store.cart && $store.cart.count > 0" x-text="$store.cart?.count" x-cloak class="absolute top-1 right-2 min-w-[16px] h-4 px-1 rounded-full text-[9px] font-bold text-white accent-bg flex items-center justify-center"></span>
            </button>
            <a href="/account" class="vv-mobile-nav-item">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Account
            </a>
        </div>
    </div>

    {{ mcsets_scripts() }}
    {% block scripts %}{% endblock %}
</body>
</html>