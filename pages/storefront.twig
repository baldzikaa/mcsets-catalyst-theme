{% extends 'layouts/base.twig' %}
{% block title %}{{ store.name|striptags }} — Store{% endblock %}

{% block content %}
{% include 'components/navbar.twig' %}

{# Full-page blurred banner background #}
<div class="fixed inset-0 z-0 pointer-events-none" style="top:56px;">
    {% if store.banner %}
        <img src="{{ storage_url(store.banner) }}" alt="" class="vv-hero-bg">
    {% else %}
        <div class="absolute inset-0" style="background:linear-gradient(160deg, color-mix(in srgb, var(--vv-accent), #0c0e14 82%) 0%, #0c0e14 60%);"></div>
    {% endif %}
    <div class="vv-hero-overlay"></div>
</div>

{{ addon_zone('storefront.header_banner') }}

{# Flash sale #}
{% if flash_sale %}
<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-4" style="margin-top:56px;" x-data="flashSaleCountdown('{{ flash_sale.ends_at }}')">
    <div style="background:linear-gradient(90deg,#f59e0b,#ef4444); border-radius:var(--vv-r); padding:12px 16px; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <div>
                <p style="font-size:15px; font-weight:800; color:#fff;">{{ flash_sale.name }}</p>
                <p style="font-size:12px; color:rgba(255,255,255,.8);">{{ flash_sale.discount_type == 'percentage' ? flash_sale.discount_value ~ '% OFF' : '£' ~ flash_sale.discount_value ~ ' OFF' }}</p>
            </div>
        </div>
        <div class="flex items-center gap-2 text-center">
            {% for label, val in {'HRS': 'hours', 'MIN': 'minutes', 'SEC': 'seconds'} %}
            {% if not loop.first %}<span style="color:#fff; font-weight:800;">:</span>{% endif %}
            <div style="background:rgba(255,255,255,.2); border-radius:6px; padding:6px 10px; min-width:44px;">
                <div style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:900; color:#fff;" x-text="{{ val }}.toString().padStart(2,'0')">00</div>
                <div style="font-size:8px; color:rgba(255,255,255,.8); text-transform:uppercase;">{{ label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

{# Upgrade offers #}
<div class="relative z-10" style="margin-top: {{ flash_sale ? '8px' : '56px' }};" x-data="{ init() { const u = localStorage.getItem('mcsets_username'); if (u) $store.upgrades.fetchOffers(u); } }" x-init="init()">
    <template x-if="$store.upgrades.offers.length > 0">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-4">
            <template x-for="offer in $store.upgrades.offers" :key="offer.existing_package.id">
                <div x-show="!$store.upgrades.dismissedOffers.includes(offer.existing_package.id)" class="flex items-center justify-between gap-4 p-4 rounded-xl mb-3 flex-wrap" style="background:linear-gradient(90deg,#059669,#0891b2);">
                    <button @click="$store.upgrades.dismissOffer(offer.existing_package.id)" class="absolute top-3 right-3 w-6 h-6 rounded-full flex items-center justify-center text-white" style="background:rgba(255,255,255,.2);">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                    <div style="color:#fff; font-size:14px; font-weight:700;">Upgrade to <span x-text="offer.upgrade_package.name"></span></div>
                    <a :href="'/package/' + offer.upgrade_package.slug" style="background:#fff; color:#059669; padding:6px 16px; border-radius:8px; font-size:12px; font-weight:800; text-decoration:none;">Upgrade — <span x-text="$store.upgrades.formatPrice(offer.upgrade_package.upgrade_price)"></span></a>
                </div>
            </template>
        </div>
    </template>
</div>

{# Main layout #}
<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6" style="{{ flash_sale or (store.upgrades is defined) ? '' : 'padding-top: calc(56px + 24px);' }}">
    <div class="flex gap-6">

        {# Main content #}
        <main class="flex-1 min-w-0 space-y-6">

            {% if active_category %}
            {# ── CATEGORY VIEW — product tiles ───────────── #}
            <div class="vv-animate-up">
                <div class="flex items-center gap-3 mb-2">
                    <a href="/" style="display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:700; color:var(--vv-muted); text-decoration:none;" onmouseover="this.style.color='var(--vv-text)'" onmouseout="this.style.color='var(--vv-muted)'">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        Back
                    </a>
                </div>
                <div class="vv-section-head">
                    {% if active_category.icon_path %}
                    <div style="width:32px; height:32px; border-radius:8px; background:var(--vv-surface2); border:1px solid var(--vv-border); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        {{ editable_icon(active_category.icon_path, active_category.id, 'w-4 h-4', '16') }}
                    </div>
                    {% else %}
                    <svg class="w-5 h-5 flex-shrink-0" style="color:var(--vv-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                    {% endif %}
                    <h1 class="vv-section-title">{{ editable(active_category.name,'category',active_category.id,'name') }}</h1>
                    <div class="vv-section-line"></div>
                    {% if packages|length > 0 %}<span style="font-size:11px; font-weight:700; color:var(--vv-dim); background:var(--vv-surface2); border:1px solid var(--vv-border); padding:2px 8px; border-radius:10px;">{{ packages|length }}</span>{% endif %}
                </div>
                {% if active_category.description %}
                <p style="font-size:13px; color:var(--vv-muted); margin-bottom:16px;">{{ editable(active_category.description,'category',active_category.id,'description') }}</p>
                {% endif %}
            </div>

            {{ addon_zone('storefront.above_packages') }}

            {% if packages|length == 0 %}
            <div style="background:var(--vv-surface); border:1px solid var(--vv-border); border-radius:var(--vv-r-lg); padding:48px; text-align:center;">
                <p style="font-size:14px; color:var(--vv-muted); font-weight:600;">No packages in this category yet.</p>
            </div>
            {% else %}
            <div class="vv-pkg-grid">
                {% for package in packages %}
                {{ mcsets_sortable_package_start(package) }}
                <div style="animation: vv-up .35s ease both {{ loop.index * 0.05 }}s;">
                    {% include 'components/package-card.twig' with { package: package } %}
                </div>
                {{ mcsets_sortable_package_end() }}
                {% endfor %}
            </div>
            {% endif %}

            {{ addon_zone('storefront.below_packages') }}
            {{ mcsets_hide_packages_toggle() }}

            {% else %}
            {# ── HOME VIEW — category tiles ───────────────── #}

            {# Welcome card #}
            <div class="vv-cut" style="background:var(--vv-surface); border:1px solid var(--vv-border); padding:24px 28px; animation: vv-up .4s ease both .1s;">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 flex-shrink-0" style="color:var(--vv-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <p style="font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:var(--vv-accent);">
                        {{ editable(settings.welcome_text|default('Welcome'), 'settings', 0, 'welcome_text') }}
                    </p>
                </div>
                <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:32px; font-weight:900; color:var(--vv-text); text-transform:uppercase; line-height:1; margin-bottom:8px;">
                    {{ editable(store.name,'store',store.id,'store_name') }}
                </h2>
                <p style="font-size:14px; color:var(--vv-muted); line-height:1.6;">{{ editable(store.description|default('Browse our packages below and support the server!'), 'store', store.id, 'store_description') }}</p>
            </div>

            {% for section in sections_above_packages|default([]) %}
            {{ mcsets_sortable_content_section_start(section) }}
            <div class="vv-card p-5 sm:p-6">
                {% if section.subtitle %}<p style="font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-accent); margin-bottom:4px;">{{ editable(section.subtitle,'content_section',section.id,'subtitle') }}</p>{% endif %}
                <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:800; color:var(--vv-text); text-transform:uppercase; margin-bottom:8px;">{{ editable(section.title,'content_section',section.id,'title') }}</h2>
                {% if section.description %}<p style="font-size:14px; color:var(--vv-muted);">{{ editable(section.description,'content_section',section.id,'description') }}</p>{% endif %}
            </div>
            {{ mcsets_sortable_content_section_end() }}
            {% endfor %}
            {{ mcsets_add_content_section_btn('above_packages') }}
            {{ addon_zone('storefront.above_packages') }}

            {# Category tiles #}
            <div style="animation: vv-up .4s ease both .2s;">
                <div class="vv-section-head">
                    <svg class="w-5 h-5 flex-shrink-0" style="color:var(--vv-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    <h2 class="vv-section-title">Shop by Category</h2>
                    <div class="vv-section-line"></div>
                </div>
                {% include 'components/category-sidebar.twig' %}
            </div>

            {# Featured packages #}
            {% if featured_packages|default([])|length > 0 %}
            <div style="animation: vv-up .4s ease both .3s;">
                <div class="vv-section-head">
                    <svg class="w-5 h-5 flex-shrink-0 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <h2 class="vv-section-title">Featured</h2>
                    <div class="vv-section-line"></div>
                </div>
                <div class="vv-pkg-grid">
                    {% for package in featured_packages %}
                    {{ mcsets_sortable_package_start(package) }}
                    <div style="animation: vv-up .35s ease both {{ 0.3 + loop.index * 0.05 }}s;">
                        {% include 'components/package-card.twig' with { package: package } %}
                    </div>
                    {{ mcsets_sortable_package_end() }}
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% for section in sections_below_packages|default([]) %}
            {{ mcsets_sortable_content_section_start(section) }}
            <div class="vv-card p-5 sm:p-6">
                {% if section.subtitle %}<p style="font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-accent); margin-bottom:4px;">{{ editable(section.subtitle,'content_section',section.id,'subtitle') }}</p>{% endif %}
                <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:800; color:var(--vv-text); text-transform:uppercase; margin-bottom:8px;">{{ editable(section.title,'content_section',section.id,'title') }}</h2>
                {% if section.description %}<p style="font-size:14px; color:var(--vv-muted);">{{ editable(section.description,'content_section',section.id,'description') }}</p>{% endif %}
            </div>
            {{ mcsets_sortable_content_section_end() }}
            {% endfor %}
            {{ addon_zone('storefront.below_packages') }}
            {{ mcsets_hide_packages_toggle() }}

            {% endif %}
        </main>

        {# Sidebar — desktop only #}
        {% if donations.enabled|default(false) %}
        <aside class="hidden xl:flex flex-col gap-4 w-[240px] flex-shrink-0 pt-0">

            {# Donation goal ring #}
            {% if donation_goal %}
            {% if mcsets_show_section('top_supporter') %}
            {{ mcsets_sortable_section_start('top_supporter') }}
            <div class="vv-side-card" style="animation: vv-up .4s ease both .35s;">
                <div class="vv-side-card-head">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {{ editable(settings.monthly_goal_title|default('Monthly Goal'), 'settings', 0, 'monthly_goal_title') }}
                </div>
                <div class="p-4 flex flex-col items-center gap-3">
                    {# Ring #}
                    <div class="vv-ring-wrap">
                        {% set circ = 251.2 %}
                        {% set filled = (donation_goal.percentage > 100 ? 100 : donation_goal.percentage) / 100 * circ %}
                        <svg width="120" height="120" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" r="40" class="vv-ring-track" stroke-width="9"/>
                            <circle cx="50" cy="50" r="40" class="vv-ring-fill" stroke-width="9"
                                    stroke-dasharray="{{ filled|round(1) }} {{ circ }}"
                                    stroke-dashoffset="0"/>
                        </svg>
                        <div class="vv-ring-label">
                            <div class="vv-ring-pct">{{ donation_goal.percentage }}%</div>
                            <div class="vv-ring-sub">Goal</div>
                        </div>
                    </div>
                    <div class="text-center w-full">
                        <p style="font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; color:var(--vv-green);">{{ price(donation_goal.current) }}</p>
                        <p style="font-size:11px; color:var(--vv-dim);">of {{ price(donation_goal.target) }} goal</p>
                        <div class="w-full rounded-full mt-2" style="height:4px; background:var(--vv-surface3);">
                            <div class="rounded-full accent-bg" style="height:100%; width:{{ donation_goal.percentage > 100 ? 100 : donation_goal.percentage }}%; transition:width 1s ease;"></div>
                        </div>
                    </div>
                </div>
            </div>
            {{ mcsets_sortable_section_end() }}
            {% endif %}
            {% endif %}

            {# Top supporter #}
            {% if mcsets_show_section('top_supporter') %}
            {{ mcsets_sortable_section_start('top_supporter') }}
            <div class="vv-side-card" style="animation: vv-up .4s ease both .4s;">
                <div class="vv-side-card-head">
                    <svg class="w-3.5 h-3.5" style="color:var(--vv-accent);" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5z"/></svg>
                    {{ editable(settings.top_supporter_title|default('Top Supporter'), 'settings', 0, 'top_supporter_title') }}
                </div>
                <div class="p-4 flex items-center gap-3">
                    <div class="relative top-[-14px] h-[52px] overflow-hidden flex-shrink-0">
                        <img src="https://starlightskins.lunareclipse.studio/render/ultimate/{{ top_donator.username|default('MHF_Question') }}/full" alt="" class="h-[90px] w-auto">
                    </div>
                    <div>
                        <p style="font-size:13px; font-weight:800; color:var(--vv-accent);">{{ top_donator.username|default('Nobody yet') }}</p>
                        <p style="font-size:11px; color:var(--vv-dim);">{{ editable(settings.top_supporter_subtitle|default('Most this month'), 'settings', 0, 'top_supporter_subtitle') }}</p>
                    </div>
                </div>
            </div>
            {{ mcsets_sortable_section_end() }}
            {% endif %}

            {# Recent payments #}
            {% if mcsets_show_section('recent_payments') %}
            {{ mcsets_sortable_section_start('recent_payments') }}
            <div class="vv-side-card" style="animation: vv-up .4s ease both .45s;">
                <div class="vv-side-card-head">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    {{ editable(settings.recent_payments_title|default('Recent Payments'), 'settings', 0, 'recent_payments_title') }}
                </div>
                <div class="p-4">
                    {% if recent_payments|default([])|length > 0 %}
                    <div class="flex flex-wrap gap-1.5">
                        {% for payment in recent_payments|slice(0,10) %}
                        <div class="relative group">
                            <img src="{{ mc_head(payment.username, 48) }}" alt="{{ payment.username }}" class="vv-avatar">
                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2 py-1 rounded text-[10px] text-white whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-20" style="background:rgba(0,0,0,.85);">
                                {{ payment.username }} — <span class="price-text">{{ price(payment.amount) }}</span>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <p style="font-size:12px; color:var(--vv-dim);">No payments yet.</p>
                    {% endif %}
                </div>
            </div>
            {{ mcsets_sortable_section_end() }}
            {% endif %}

            {# Gift cards #}
            {% if gift_cards.enabled|default(false) %}
            {% if mcsets_show_section('gift_cards') %}
            {{ mcsets_sortable_section_start('gift_cards') }}
            <div class="vv-side-card" x-data="giftCardPurchase()" style="animation: vv-up .4s ease both .5s;">
                <div class="vv-side-card-head">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
                    {{ editable(settings.gift_cards_label|default('Gift Cards'), 'settings', 0, 'gift_cards_label') }}
                </div>
                <div class="p-4 space-y-3">
                    {% if gift_cards.amounts is defined and gift_cards.amounts|length > 0 %}
                    <div class="flex flex-wrap gap-1.5">
                        {% for amount in gift_cards.amounts %}
                        <button @click="customAmount = {{ amount }}" :class="parseFloat(customAmount) === {{ amount }} ? 'accent-bg text-white' : ''" class="px-2.5 py-1 rounded-lg text-xs font-bold transition-all" style="border:1px solid var(--vv-border); color:var(--vv-muted);">${{ amount }}</button>
                        {% endfor %}
                    </div>
                    {% endif %}
                    <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold" style="color:var(--vv-muted);">£</span><input type="number" x-model="customAmount" min="1" max="500" step="0.01" placeholder="Amount" class="vv-input pl-7" style="font-size:13px; padding:8px 10px 8px 28px;"></div>
                    <button @click="purchaseGiftCard()" :disabled="!selectedAmount || loading || success" class="vv-btn vv-btn-primary w-full" style="font-size:12px; padding:8px;">
                        <span x-show="!loading && !success">Add to Cart</span>
                        <span x-show="success" x-cloak>✓ Added!</span>
                        <span x-show="loading" x-cloak class="flex items-center gap-2"><span class="vv-spinner"></span>Adding...</span>
                    </button>
                </div>
            </div>
            {{ mcsets_sortable_section_end() }}
            {% endif %}
            {% endif %}

            {{ addon_zone('storefront.sidebar') }}
        </aside>
        {% endif %}

    </div>
</div>

{{ addon_zone('storefront.footer') }}
{% endblock %}
