{% extends 'layouts/base.twig' %}{% block title %}Order Complete — {{ store.name|striptags }}{% endblock %}
{% block content %}{% include 'components/navbar.twig' %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 pb-16 text-center relative z-10" style="padding-top:calc(56px + 48px);">
    <div class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center accent-bg" style="box-shadow:0 0 32px var(--vv-accent-ghost);">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:40px; font-weight:900; color:var(--vv-text); text-transform:uppercase; margin-bottom:8px;">Order Complete!</h1>
    <p style="font-size:14px; color:var(--vv-muted); margin-bottom:28px;">{% if player_username %}Items delivered to <strong style="color:var(--vv-text);">{{ player_username }}</strong>. {% endif %}Thank you for your purchase!</p>
    {% if order %}<div class="vv-card p-5 mb-6 text-left"><div style="font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-dim); margin-bottom:4px;">Order ID</div><div style="font-size:13px; font-family:monospace; color:var(--vv-muted); margin-bottom:10px;">{{ order.id }}</div><div style="font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--vv-dim); margin-bottom:4px;">Total</div><div style="font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; color:var(--vv-green);">{{ order.total|localized_price }}</div></div>{% endif %}
    {% if gift_cards is defined and gift_cards|length > 0 %}<div class="space-y-3 mb-6 text-left">{% for card in gift_cards %}<div class="vv-card p-5" x-data="{ copied: false }"><div class="flex items-center justify-between mb-3"><div style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:800; color:var(--vv-green);">{{ card.amount|localized_price }}</div><div style="font-size:11px; color:var(--vv-dim);">Expires {{ card.expires_at }}</div></div><div class="flex items-center gap-3 px-4 py-3 rounded-xl" style="background:var(--vv-surface2);"><div style="flex:1; font-size:18px; font-family:monospace; font-weight:800; color:var(--vv-text); letter-spacing:.1em;">{{ card.code }}</div><button @click="navigator.clipboard.writeText('{{ card.code }}'); copied = true; setTimeout(() => copied = false, 2000)" class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:var(--vv-surface3);"><template x-if="!copied"><svg class="w-4 h-4" style="color:var(--vv-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg></template><template x-if="copied"><svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></template></button></div></div>{% endfor %}</div>{% endif %}
    <a href="/" class="vv-btn vv-btn-primary" style="font-size:14px;">Continue Shopping</a>
</div>{% endblock %}